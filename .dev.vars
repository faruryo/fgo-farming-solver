NEXTJS_ENV=development

# This file is tracked in git — do not put real secrets here.
# Web Push VAPID keys for local dev live in .env.local (gitignored) instead;
# see VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY there. In production,
# VAPID_PUBLIC_KEY is set via `wrangler secret put VAPID_PUBLIC_KEY`;
# VAPID_PRIVATE_KEY is only ever set as a GitHub Secret for the GHA
# dispatcher script (scripts/send-todo-notifications.ts) and is never a
# Wrangler secret.
