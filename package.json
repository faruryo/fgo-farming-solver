{
  "name": "fgo-farming-solver",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx @opennextjs/cloudflare build --skipBuild && node scripts/remove-fetch-cache.mjs",
    "deploy": "npm run build && wrangler deploy",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write --ignore-path .gitignore ./**/*.{js,jsx,ts,tsx}",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "update-data": "tsx scripts/update-data.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1026.0",
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@chakra-ui/accordion": "^2.3.1",
    "@chakra-ui/breadcrumb": "^2.2.0",
    "@chakra-ui/button": "^2.1.0",
    "@chakra-ui/checkbox": "^2.3.2",
    "@chakra-ui/form-control": "^2.2.0",
    "@chakra-ui/hooks": "^2.4.5",
    "@chakra-ui/icons": "^2.1.1",
    "@chakra-ui/input": "^2.1.2",
    "@chakra-ui/layout": "^2.3.1",
    "@chakra-ui/menu": "^2.2.1",
    "@chakra-ui/next-js": "^2.4.2",
    "@chakra-ui/react": "^2.10.9",
    "@chakra-ui/system": "^2.6.2",
    "@chakra-ui/table": "^2.1.0",
    "@chakra-ui/utils": "^2.2.5",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "framer-motion": "^11.18.2",
    "i18next": "^26.0.4",
    "javascript-lp-solver": "^1.0.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.2",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@opennextjs/cloudflare": "^1.19.5",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "raw-loader": "^4.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "workerd": "^1.20260411.1",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "esbuild": "0.28.0",
    "yaml": "2.8.3",
    "@emnapi/runtime": "1.9.2",
    "@emnapi/core": "1.9.2"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux",
        "darwin"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    },
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
