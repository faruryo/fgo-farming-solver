{
  "name": "fgo-farming-solver",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx @opennextjs/cloudflare build --skipBuild && node scripts/remove-fetch-cache.mjs",
    "deploy": "pnpm run build && pnpm exec wrangler deploy",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write --ignore-path .gitignore ./**/*.{js,jsx,ts,tsx}",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "update-data": "tsx scripts/update-data.ts",
    "update:mock:dashboard": "tsx scripts/update-mock-dashboard.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1026.0",
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "i18next": "^26.0.4",
    "javascript-lp-solver": "^1.0.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.2",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.1",
    "recharts": "2.15.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@opennextjs/cloudflare": "^1.19.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "workerd": "^1.20260411.1",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "esbuild": "0.28.0",
    "yaml": "2.8.3",
    "@emnapi/runtime": "1.9.2",
    "@emnapi/core": "1.9.2"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux",
        "darwin"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    },
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
